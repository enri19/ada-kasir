{
  "expo": {
    "name": "AdaKasir",
    "slug": "ada-kasir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "AdaKasir",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "adakasir",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adakasir.app"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icons/receipt.png",
        "monochromeImage": "./assets/icons/receipt.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.adakasir.app"
    },
    "web": {
      "favicon": "./assets/icons/logo.png"
    }
  }
}
